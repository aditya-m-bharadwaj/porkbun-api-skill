#!/usr/bin/env python3
"""porkbun-api-skill — safe, cross-platform CLI for the entire Porkbun v3 API.

AI-AUTHORED: This file was generated by Claude (Anthropic, Claude Opus 4.7).
Read AUTHORS.md for the full disclaimer. Audit the code before trusting it
with a production Porkbun account.

The credentials are loaded at run time from an OS-native secret store when
possible. Porkbun uses TWO secrets (apikey + secretapikey) stored as one JSON
blob:

  * macOS:  Keychain (via `security`)
  * Linux:  Secret Service (via `secret-tool`) if libsecret is installed
  * Windows / fallback: file at ~/.porkbun-api-skill/credentials.json, mode 0600

Process model:
  - Both keys are held only in this Python process's memory for the duration
    of one CLI call. They never end up in argv, env vars exported to children,
    log files, or stdout.
  - Every POST passes through a safety classifier that requires explicit
    operator-supplied flags. The classifier is defensive: unknown mutating
    endpoints default to the strictest applicable bucket.
  - Every POST (write or read-style) carries an `Idempotency-Key` header so
    that a retried call cannot double-charge or double-create. The key is a
    UUIDv4 generated per call.
  - Every mutation appends one JSON line to ~/.porkbun-api-skill/audit.log.

Stdlib only — no third-party deps.
"""

from __future__ import annotations

import argparse
import datetime as dt
import getpass
import json
import os
import pathlib
import re
import subprocess
import sys
import urllib.error
import urllib.parse
import urllib.request
import uuid
from typing import Any, Iterable

VERSION = "0.1.0-alpha.1"
API_BASE = "https://api.porkbun.com/api/json/v3"
KEYSTORE_SERVICE = "porkbun-api-skill"
USER_AGENT = f"porkbun-api-skill/{VERSION}"

# Validation regexes
DOMAIN_RE = re.compile(r"^(?=.{1,253}$)(xn--[a-z0-9-]+|[a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)(\.(xn--[a-z0-9-]+|[a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?))+$")
SUBDOMAIN_RE = re.compile(r"^([a-zA-Z0-9_*-]{1,63})(\.[a-zA-Z0-9_*-]{1,63})*$")
DNS_TYPE_RE = re.compile(r"^[A-Z][A-Z0-9]{0,15}$")
PATH_RE = re.compile(r"^/[A-Za-z0-9/_.{}-]{0,512}$")
RECORD_ID_RE = re.compile(r"^[0-9]{1,32}$")

CONFIG_DIR = pathlib.Path.home() / ".porkbun-api-skill"
SSL_DIR = CONFIG_DIR / "ssl"
AUDIT_LOG = CONFIG_DIR / "audit.log"
CREDS_FILE = CONFIG_DIR / "credentials.json"


# ---------- Errors ---------------------------------------------------------


class CtlError(Exception):
    """User-facing error. Message is safe to print."""


# ---------- Platform helpers -----------------------------------------------


def _platform() -> str:
    p = sys.platform
    if p == "darwin":
        return "macos"
    if p.startswith("linux"):
        return "linux"
    if p in ("win32", "cygwin"):
        return "windows"
    return "unknown"


def _which(cmd: str) -> str | None:
    for d in (os.environ.get("PATH") or "").split(os.pathsep):
        p = pathlib.Path(d) / cmd
        if p.is_file() and os.access(p, os.X_OK):
            return str(p)
        if _platform() == "windows":
            for ext in (".exe", ".cmd", ".bat"):
                p2 = pathlib.Path(d) / (cmd + ext)
                if p2.is_file():
                    return str(p2)
    return None


def _account() -> str:
    return getpass.getuser() or "default"


# ---------- Credential store (cross-platform, dual-key) --------------------
#
# Porkbun authenticates with a PAIR of secrets: `apikey` (looks like `pk1_...`)
# and `secretapikey` (looks like `sk1_...`). We store them as a single JSON
# blob `{"apikey": "...", "secretapikey": "..."}` so the keystore entry is
# atomic — you cannot rotate one without the other.
#
# The CLI never returns a single key; either both or neither are present.


def _pack(apikey: str, secretapikey: str) -> str:
    return json.dumps({"apikey": apikey, "secretapikey": secretapikey})


def _unpack(blob: str) -> tuple[str, str] | None:
    try:
        data = json.loads(blob)
    except json.JSONDecodeError:
        return None
    a = (data.get("apikey") or "").strip()
    s = (data.get("secretapikey") or "").strip()
    if not a or not s:
        return None
    return (a, s)


def _kc_get_macos() -> str | None:
    if _which("security") is None:
        return None
    res = subprocess.run(
        ["security", "find-generic-password", "-s", KEYSTORE_SERVICE, "-a", _account(), "-w"],
        check=False, capture_output=True, text=True,
    )
    if res.returncode != 0:
        return None
    blob = res.stdout.strip()
    return blob or None


def _kc_set_macos(blob: str) -> None:
    res = subprocess.run(
        ["security", "add-generic-password",
         "-s", KEYSTORE_SERVICE, "-a", _account(),
         "-w", blob, "-T", "", "-U"],
        check=False, capture_output=True, text=True,
    )
    if res.returncode != 0:
        raise CtlError(f"macOS Keychain store failed: {res.stderr.strip()}")


def _kc_delete_macos() -> None:
    subprocess.run(
        ["security", "delete-generic-password", "-s", KEYSTORE_SERVICE, "-a", _account()],
        check=False, capture_output=True,
    )


def _kc_get_linux() -> str | None:
    if _which("secret-tool") is None:
        return None
    res = subprocess.run(
        ["secret-tool", "lookup", "service", KEYSTORE_SERVICE, "account", _account()],
        check=False, capture_output=True, text=True,
    )
    if res.returncode != 0:
        return None
    blob = res.stdout.strip()
    return blob or None


def _kc_set_linux(blob: str) -> None:
    if _which("secret-tool") is None:
        raise CtlError("secret-tool not found. Install libsecret-tools (Debian/Ubuntu) or libsecret (Fedora/Arch).")
    proc = subprocess.run(
        ["secret-tool", "store", "--label", f"{KEYSTORE_SERVICE} API credentials",
         "service", KEYSTORE_SERVICE, "account", _account()],
        input=blob, check=False, capture_output=True, text=True,
    )
    if proc.returncode != 0:
        raise CtlError(f"Linux Secret Service store failed: {proc.stderr.strip()}")


def _kc_delete_linux() -> None:
    if _which("secret-tool") is None:
        return
    subprocess.run(
        ["secret-tool", "clear", "service", KEYSTORE_SERVICE, "account", _account()],
        check=False, capture_output=True,
    )


def _file_get() -> str | None:
    if not CREDS_FILE.exists():
        return None
    try:
        st = CREDS_FILE.stat()
        if os.name == "posix" and (st.st_mode & 0o077):
            raise CtlError(
                f"Refusing to read {CREDS_FILE}: permissions are {oct(st.st_mode & 0o777)}; "
                f"run `chmod 600 {CREDS_FILE}` and retry."
            )
        with CREDS_FILE.open("r", encoding="utf-8") as f:
            blob = f.read().strip()
        return blob or None
    except OSError as e:
        raise CtlError(f"Could not read {CREDS_FILE}: {e}") from None


def _file_set(blob: str) -> None:
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    if os.name == "posix":
        os.chmod(CONFIG_DIR, 0o700)
    flags = os.O_WRONLY | os.O_CREAT | os.O_TRUNC
    fd = os.open(str(CREDS_FILE), flags, 0o600)
    try:
        os.write(fd, (blob + "\n").encode("utf-8"))
    finally:
        os.close(fd)
    if os.name == "posix":
        os.chmod(CREDS_FILE, 0o600)
    elif os.name == "nt":
        try:
            user = os.environ.get("USERNAME") or _account()
            subprocess.run(
                ["icacls", str(CREDS_FILE), "/inheritance:r", "/grant:r", f"{user}:F"],
                check=False, capture_output=True, text=True,
            )
        except FileNotFoundError:
            pass


def _file_delete() -> None:
    if CREDS_FILE.exists():
        CREDS_FILE.unlink()


def creds_get() -> tuple[str, str] | None:
    plat = _platform()
    blob: str | None = None
    if plat == "macos":
        blob = _kc_get_macos()
    elif plat == "linux":
        blob = _kc_get_linux()
    if blob is None:
        blob = _file_get()
    if blob is None:
        # Env fallback — both must be set.
        env_a = (os.environ.get("PORKBUN_API_KEY") or "").strip()
        env_s = (os.environ.get("PORKBUN_SECRET_API_KEY") or "").strip()
        if env_a and env_s:
            return (env_a, env_s)
        return None
    return _unpack(blob)


def creds_set(apikey: str, secretapikey: str, prefer: str | None = None) -> str:
    """Store the credential pair. Returns a human description of where it landed."""
    blob = _pack(apikey, secretapikey)
    plat = _platform()
    if prefer == "file" or plat == "windows" or plat == "unknown":
        if plat == "macos":
            _kc_delete_macos()
        elif plat == "linux":
            _kc_delete_linux()
        _file_set(blob)
        return f"file {CREDS_FILE} (mode 600)"
    if plat == "macos":
        _kc_set_macos(blob)
        _file_delete()
        return f"macOS Keychain (service={KEYSTORE_SERVICE})"
    if plat == "linux":
        if _which("secret-tool"):
            _kc_set_linux(blob)
            _file_delete()
            return f"Linux Secret Service (service={KEYSTORE_SERVICE})"
        _file_set(blob)
        return (
            f"file {CREDS_FILE} (mode 600). For stronger storage install libsecret-tools "
            "and re-run setup."
        )
    _file_set(blob)
    return f"file {CREDS_FILE} (mode 600)"


def creds_delete() -> list[str]:
    removed = []
    plat = _platform()
    if plat == "macos":
        _kc_delete_macos()
        removed.append("macOS Keychain")
    if plat == "linux":
        _kc_delete_linux()
        removed.append("Linux Secret Service (if present)")
    if CREDS_FILE.exists():
        _file_delete()
        removed.append(str(CREDS_FILE))
    return removed


def _load_creds() -> tuple[str, str]:
    c = creds_get()
    if c:
        return c
    raise CtlError(
        "No Porkbun API credentials found. Run `porkbun-api-skill setup` interactively, "
        "or `porkbun-api-skill gui-setup` for the AI-safe GUI flow. "
        "Generate a key pair at https://porkbun.com/account/api."
    )


# ---------- GUI dialogs (AI-safe credential entry) -------------------------
#
# These helpers pop up native desktop dialogs for credential entry. The dialog
# is rendered by the OS WindowServer/compositor — it is not part of any pipe
# or stdout the AI can observe. The user's keystrokes are returned via
# subprocess stdout, captured into Python memory, and discarded after the
# keystore write.


def _has_display() -> bool:
    if os.environ.get("SSH_CONNECTION") or os.environ.get("SSH_TTY"):
        return False
    plat = _platform()
    if plat == "linux":
        return bool(os.environ.get("DISPLAY") or os.environ.get("WAYLAND_DISPLAY"))
    return True


def _no_gui_error() -> CtlError:
    plat = _platform()
    if plat == "linux":
        return CtlError(
            "No GUI password dialog available.\n"
            "Either:\n"
            "  - Install zenity:  sudo apt install zenity   (Debian/Ubuntu)\n"
            "                     sudo dnf install zenity   (Fedora)\n"
            "                     sudo pacman -S zenity     (Arch)\n"
            "  - Or run `porkbun-api-skill setup` directly in your terminal."
        )
    if plat == "windows":
        return CtlError(
            "PowerShell not found. Either install PowerShell, or run "
            "`porkbun-api-skill setup` in your terminal directly."
        )
    return CtlError(
        "Native GUI credential entry is not available on this platform. "
        "Run `porkbun-api-skill setup` in your terminal directly."
    )


def _macos_password_dialog(title: str, prompt: str) -> str:
    safe_prompt = prompt.replace("\\", "\\\\").replace('"', '\\"').replace("\n", "\\n")
    safe_title = title.replace("\\", "\\\\").replace('"', '\\"')
    script = (
        f'set t to text returned of (display dialog "{safe_prompt}" '
        f'default answer "" with hidden answer '
        f'with title "{safe_title}" '
        f'buttons {{"Cancel","OK"}} default button "OK")\n'
        f'return t'
    )
    try:
        proc = subprocess.run(
            ["osascript", "-e", script],
            check=False, capture_output=True, text=True, timeout=300,
        )
    except subprocess.TimeoutExpired:
        raise CtlError("Credential entry timed out (5 minutes).") from None
    if proc.returncode != 0:
        err = (proc.stderr or "").strip()
        if "User canceled" in err or "cancelled" in err.lower():
            raise CtlError("Credential entry cancelled.")
        raise CtlError(f"GUI dialog failed: {err[:200]}")
    return proc.stdout.strip()


def _prompt_creds_gui() -> tuple[str, str]:
    """Pop native dialog(s), return (apikey, secretapikey).

    Captured bytes never re-emerge from this function via stdout/stderr.
    See cmd_gui_setup, which prints only success/failure metadata.
    """
    if not _has_display():
        raise CtlError(
            "No display server detected (DISPLAY/WAYLAND_DISPLAY unset). "
            "GUI credential entry needs a desktop session. Run `porkbun-api-skill setup` "
            "directly in the terminal you are using."
        )
    plat = _platform()

    if plat == "macos":
        if _which("osascript") is None:
            raise _no_gui_error()
        a = _macos_password_dialog(
            "porkbun-api-skill — API key (1 of 2)",
            "Paste your Porkbun API key (starts with `pk1_`).\n\n"
            "Input is hidden. The AI assistant cannot see what you type into this dialog.",
        )
        s = _macos_password_dialog(
            "porkbun-api-skill — Secret API key (2 of 2)",
            "Paste your Porkbun SECRET API key (starts with `sk1_`).\n\n"
            "Input is hidden. The AI assistant cannot see what you type into this dialog.",
        )
        return (a, s)

    if plat == "linux":
        if _which("zenity"):
            try:
                proc = subprocess.run(
                    ["zenity", "--forms",
                     "--title=porkbun-api-skill — API credentials",
                     "--text=Paste both Porkbun keys (input is hidden; AI cannot read it).",
                     "--add-password=API key (pk1_...)",
                     "--add-password=Secret API key (sk1_...)",
                     "--separator=\x1f"],
                    check=False, capture_output=True, text=True, timeout=300,
                )
            except subprocess.TimeoutExpired:
                raise CtlError("Credential entry timed out (5 minutes).") from None
            if proc.returncode != 0:
                raise CtlError("Credential entry cancelled or unavailable.")
            parts = proc.stdout.rstrip("\n").split("\x1f")
            if len(parts) != 2:
                raise CtlError("Unexpected dialog output (could not split into two fields).")
            return (parts[0].strip(), parts[1].strip())
        if _which("kdialog"):
            try:
                a_proc = subprocess.run(
                    ["kdialog", "--title", "porkbun-api-skill — API key (1 of 2)",
                     "--password",
                     "Paste your Porkbun API key (pk1_...). Input is hidden; AI cannot read it."],
                    check=False, capture_output=True, text=True, timeout=300,
                )
                if a_proc.returncode != 0:
                    raise CtlError("Credential entry cancelled or unavailable.")
                s_proc = subprocess.run(
                    ["kdialog", "--title", "porkbun-api-skill — Secret API key (2 of 2)",
                     "--password",
                     "Paste your Porkbun SECRET API key (sk1_...). Input is hidden; AI cannot read it."],
                    check=False, capture_output=True, text=True, timeout=300,
                )
            except subprocess.TimeoutExpired:
                raise CtlError("Credential entry timed out (5 minutes).") from None
            if s_proc.returncode != 0:
                raise CtlError("Credential entry cancelled or unavailable.")
            return (a_proc.stdout.strip(), s_proc.stdout.strip())
        raise _no_gui_error()

    if plat == "windows":
        shell = _which("pwsh") or _which("powershell")
        if not shell:
            raise _no_gui_error()
        # Convention: UserName = apikey, Password = secretapikey.
        ps = (
            "$cred = Get-Credential -UserName 'paste-apikey-here' "
            "-Message 'Paste your Porkbun API key as USERNAME (pk1_...), and your "
            "SECRET API key as PASSWORD (sk1_...). The AI cannot read these.' ; "
            "if ($null -eq $cred) { exit 1 } ; "
            "Write-Output $cred.UserName ; "
            "Write-Output $cred.GetNetworkCredential().Password"
        )
        try:
            proc = subprocess.run(
                [shell, "-NoProfile", "-Command", ps],
                check=False, capture_output=True, text=True, timeout=300,
            )
        except subprocess.TimeoutExpired:
            raise CtlError("Credential entry timed out (5 minutes).") from None
        if proc.returncode != 0:
            raise CtlError("Credential entry cancelled or unavailable.")
        lines = proc.stdout.splitlines()
        if len(lines) < 2:
            raise CtlError("Unexpected dialog output (expected two lines).")
        return (lines[0].strip(), lines[1].strip())

    raise _no_gui_error()


def _confirm_gui(prompt: str) -> bool:
    """Pop a native yes/no dialog. True = user confirmed."""
    if not _has_display():
        return False
    plat = _platform()
    if plat == "macos":
        if _which("osascript") is None:
            return False
        safe = "".join(c for c in prompt if c == "\n" or c >= " ")
        safe = safe.replace("\\", "\\\\").replace('"', '\\"').replace("\n", "\\n")
        script = (
            f'set theBtn to button returned of '
            f'(display dialog "{safe}" '
            f'buttons {{"Cancel","Replace"}} default button "Cancel" '
            f'with title "porkbun-api-skill")\n'
            f'return theBtn'
        )
        proc = subprocess.run(
            ["osascript", "-e", script],
            check=False, capture_output=True, text=True, timeout=120,
        )
        return proc.returncode == 0 and proc.stdout.strip() == "Replace"
    if plat == "linux":
        if _which("zenity"):
            proc = subprocess.run(
                ["zenity", "--question", "--title=porkbun-api-skill", f"--text={prompt}"],
                check=False, capture_output=True, text=True, timeout=120,
            )
            return proc.returncode == 0
        if _which("kdialog"):
            proc = subprocess.run(
                ["kdialog", "--title", "porkbun-api-skill", "--yesno", prompt],
                check=False, capture_output=True, text=True, timeout=120,
            )
            return proc.returncode == 0
        return False
    if plat == "windows":
        shell = _which("pwsh") or _which("powershell")
        if not shell:
            return False
        safe = prompt.replace("'", "''")
        ps = (
            "Add-Type -AssemblyName PresentationFramework; "
            f"$ans = [System.Windows.MessageBox]::Show('{safe}', 'porkbun-api-skill', 'YesNo', 'Question'); "
            "if ($ans -eq 'Yes') { exit 0 } else { exit 1 }"
        )
        proc = subprocess.run(
            [shell, "-NoProfile", "-Command", ps],
            check=False, capture_output=True, text=True, timeout=120,
        )
        return proc.returncode == 0
    return False


# ---------- HTTP layer -----------------------------------------------------


def _validate_path(path: str) -> None:
    if not PATH_RE.match(path):
        raise CtlError(f"Refusing to call malformed API path: {path!r}")
    for seg in path.split("/"):
        if seg in ("..", "."):
            raise CtlError(f"Refusing path with traversal segment {seg!r}: {path!r}")


def _strip_v3(path: str) -> str:
    # User-supplied paths copied from docs may include `/v3` or even
    # `/api/json/v3`. API_BASE already ends in `/v3` so we strip it once.
    # Use literal prefixes that include the trailing `/` so we never match
    # `/v3` against `/v30/foo`.
    for prefix in ("/api/json/v3/", "/v3/"):
        if path.startswith(prefix):
            return "/" + path[len(prefix) :]
    # Bare-prefix forms (no segments after): treat as root.
    if path in ("/api/json/v3", "/v3"):
        return "/"
    return path


def _request(
    creds: tuple[str, str],
    method: str,
    path: str,
    *,
    body: Any | None = None,
    query: dict | None = None,
    extra_headers: dict | None = None,
    idempotency_key: str | None = None,
    attach_idempotency: bool = True,
) -> Any:
    """One HTTP call. Auto-attaches X-API-Key, X-Secret-API-Key, and
    Idempotency-Key on every POST (unless attach_idempotency=False).

    Auth headers are NEVER written to logs, stdout, or error messages.
    """
    _validate_path(path)
    url = f"{API_BASE}{path}"
    if query:
        url += "?" + urllib.parse.urlencode(query)
    apikey, secretapikey = creds
    headers = {
        "X-API-Key": apikey,
        "X-Secret-API-Key": secretapikey,
        "User-Agent": USER_AGENT,
        "Accept": "application/json",
    }
    method = method.upper()
    if method == "POST" and attach_idempotency:
        headers["Idempotency-Key"] = idempotency_key or uuid.uuid4().hex
    if extra_headers:
        for k, v in extra_headers.items():
            if k.lower() in ("x-api-key", "x-secret-api-key"):
                continue  # never let callers override auth
            headers[k] = v
    data: bytes | None = None
    if body is not None:
        if isinstance(body, (bytes, bytearray)):
            data = bytes(body)
            headers.setdefault("Content-Type", "application/json")
        elif isinstance(body, str):
            data = body.encode("utf-8")
            headers.setdefault("Content-Type", "application/json")
        else:
            data = json.dumps(body).encode("utf-8")
            headers["Content-Type"] = "application/json"
    req = urllib.request.Request(url, data=data, headers=headers, method=method)
    try:
        with urllib.request.urlopen(req, timeout=60) as resp:
            raw = resp.read().decode("utf-8") or ""
            if not raw.strip():
                return {}
            try:
                return json.loads(raw)
            except json.JSONDecodeError:
                return {"_raw": raw[:4000]}
    except urllib.error.HTTPError as e:
        body_text = ""
        try:
            body_text = e.read().decode("utf-8")
            parsed = json.loads(body_text)
            # Porkbun error shape: {"status":"ERROR","message":"..."}.
            msg = parsed.get("message") or parsed.get("error") or ""
            code = parsed.get("code") or ""
            if msg:
                if code:
                    raise CtlError(f"Porkbun API {e.code} {code}: {msg}") from None
                raise CtlError(f"Porkbun API {e.code}: {msg}") from None
        except (ValueError, KeyError):
            pass
        # Strip any echo of auth headers from the body just in case.
        safe = body_text.replace(apikey, "<apikey>").replace(secretapikey, "<secretapikey>")
        raise CtlError(f"Porkbun API {e.code} {e.reason}: {safe[:400]}") from None
    except urllib.error.URLError as e:
        raise CtlError(f"Network error calling {url}: {e.reason}") from None


# ---------- Pagination -----------------------------------------------------


def _paginate_listall(creds: tuple[str, str], extra_body: dict | None = None) -> list[dict]:
    """Iterate /domain/listAll in 1000-domain chunks via `start` offset."""
    out: list[dict] = []
    start = 0
    while True:
        b: dict[str, Any] = {"start": start}
        if extra_body:
            b.update(extra_body)
        resp = _request(creds, "POST", "/domain/listAll", body=b)
        chunk = resp.get("domains") or []
        out.extend(chunk)
        if len(chunk) < 1000:
            break
        start += len(chunk)
        if start > 100_000:  # hard ceiling against runaway pagination
            break
    return out


# ---------- Audit log ------------------------------------------------------


def _audit(action: str, target: str, detail: dict) -> None:
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    if os.name == "posix":
        try:
            os.chmod(CONFIG_DIR, 0o700)
        except OSError:
            pass
    record = {
        "ts": dt.datetime.now(dt.timezone.utc).isoformat(),
        "user": _account(),
        "action": action,
        "target": target,
        "detail": detail,
    }
    line = json.dumps(record, default=str)
    with AUDIT_LOG.open("a", encoding="utf-8") as f:
        f.write(line + "\n")
    if os.name == "posix":
        try:
            os.chmod(AUDIT_LOG, 0o600)
        except OSError:
            pass


# ---------- Safety classifier ----------------------------------------------
#
# Each Porkbun endpoint is classified into one of:
#   read         — pure read; no extra confirmation
#   mutating     — in-place change; --yes required
#   destructive  — deletes a resource; --yes + --confirm-id (or --confirm-name)
#   billable     — charges account credit (register/renew/transfer)
#   privilege    — issues credentials, grants access, or returns key material
#
# Porkbun's API expresses many operations as POST (the API has no DELETE/PUT).
# A POST-to-`/delete*` route MUST be in _DESTRUCTIVE — there is no method-based
# default to catch it. Read-style POSTs (lookups that don't mutate state) are
# listed in _READ_POST so they don't fall through to `mutating`.
#
# The classifier matches the request path against a list of templates with
# bracketed placeholders ({domain}, {subdomain}, {id}, {type}, {keytag}).
# An unrecognized POST defaults to `mutating`; an unrecognized GET to `read`.

_READ_POST: set[str] = {
    "/ping",
    "/ip",
    "/pricing/get",
    "/marketplace/getAll",
    "/account/inviteStatus",
    "/domain/listAll",
    "/domain/checkDomain/{domain}",
    "/domain/getNs/{domain}",
    "/domain/getGlue/{domain}",
    "/domain/getUrlForwarding/{domain}",
    "/dns/retrieve/{domain}",
    "/dns/retrieve/{domain}/{id}",
    "/dns/retrieveByNameType/{domain}/{type}/{subdomain}",
    "/dns/getDnssecRecords/{domain}",
}

_MUTATING_EXACT: set[tuple[str, str]] = {
    ("POST", "/dns/create/{domain}"),
    ("POST", "/dns/edit/{domain}/{id}"),
    ("POST", "/dns/editByNameType/{domain}/{type}/{subdomain}"),
    ("POST", "/dns/createDnssecRecord/{domain}"),
    ("POST", "/domain/updateAutoRenew/{domain}"),
    ("POST", "/domain/updateNs/{domain}"),
    ("POST", "/domain/addUrlForward/{domain}"),
    ("POST", "/domain/createGlue/{domain}/{subdomain}"),
    ("POST", "/domain/updateGlue/{domain}/{subdomain}"),
}

_DESTRUCTIVE_EXACT: set[tuple[str, str]] = {
    ("POST", "/dns/delete/{domain}/{id}"),
    ("POST", "/dns/deleteByNameType/{domain}/{type}/{subdomain}"),
    ("POST", "/dns/deleteDnssecRecord/{domain}/{keytag}"),
    ("POST", "/domain/deleteGlue/{domain}/{subdomain}"),
    ("POST", "/domain/deleteUrlForward/{domain}/{id}"),
}

_BILLABLE_EXACT: set[tuple[str, str]] = {
    ("POST", "/domain/create/{domain}"),
    ("POST", "/domain/renew/{domain}"),
    ("POST", "/domain/transfer/{domain}"),
}

# Privilege ops: issue credentials, grant account access, or return private
# key material. SSL retrieve is privilege EVEN on GET because the response
# body contains the private key.
_PRIVILEGE_EXACT: set[tuple[str, str]] = {
    ("POST", "/apikey/request"),
    ("POST", "/apikey/retrieve"),
    ("POST", "/account/invite"),
    ("POST", "/email/setPassword"),
    ("POST", "/ssl/retrieve/{domain}"),
    ("GET",  "/ssl/retrieve/{domain}"),
}

# All known templates, ordered longest (most segments) first so more-specific
# matches win.
_ALL_TEMPLATES: list[str] = sorted(
    _READ_POST
    | {t for _, t in _MUTATING_EXACT}
    | {t for _, t in _DESTRUCTIVE_EXACT}
    | {t for _, t in _BILLABLE_EXACT}
    | {t for _, t in _PRIVILEGE_EXACT},
    key=lambda t: (-t.count("/"), -len(t)),
)


def _match_template(template: str, path: str) -> bool:
    tparts = template.strip("/").split("/")
    pparts = path.strip("/").split("/")
    if len(tparts) != len(pparts):
        return False
    for t, p in zip(tparts, pparts):
        if t.startswith("{") and t.endswith("}"):
            if not p:
                return False
            continue
        if t != p:
            return False
    return True


def _normalize_path(path: str) -> str:
    """Return the matching template (`/dns/delete/{domain}/{id}`) for `path`,
    or the stripped path if no template matches. Strips any /v3 prefix first.
    """
    p = _strip_v3(path)
    for tmpl in _ALL_TEMPLATES:
        if _match_template(tmpl, p):
            return tmpl
    return p


def classify(method: str, path: str) -> tuple[str, list[str], str]:
    """Return (classification, required_flags, human_explanation)."""
    method = method.upper()
    norm = _normalize_path(path)

    if (method, norm) in _PRIVILEGE_EXACT:
        return ("privilege", ["--yes", "--allow-privilege"],
                f"{method} {norm} issues credentials, grants account access, or returns private key material")

    if (method, norm) in _BILLABLE_EXACT:
        return ("billable", ["--yes", "--i-understand-billing"],
                f"{method} {norm} charges account credit (register/renew/transfer)")

    if (method, norm) in _DESTRUCTIVE_EXACT:
        # `deleteByNameType` deletes by subdomain pattern, not id — distinguish.
        if "deleteByNameType" in norm:
            return ("destructive", ["--yes", "--confirm-name"],
                    f"{method} {norm} permanently deletes one or more records matching a subdomain")
        return ("destructive", ["--yes", "--confirm-id"],
                f"{method} {norm} permanently deletes a resource")

    if method == "GET":
        return ("read", [], "")

    if norm in _READ_POST and method == "POST":
        return ("read", [], "")

    if (method, norm) in _MUTATING_EXACT:
        return ("mutating", ["--yes"], f"{method} {norm} is an in-place change")

    if method == "POST":
        return ("mutating", ["--yes"],
                f"{method} {norm} is an unrecognized mutation; default policy applies")

    return ("mutating", ["--yes"],
            f"{method} {norm} is unrecognized; default policy applies")


# ---------- Helpers --------------------------------------------------------


def _validate_domain(d: str) -> None:
    if not DOMAIN_RE.match(d):
        raise CtlError(f"Invalid domain name: {d!r}")


def _validate_subdomain_label(s: str) -> None:
    if s == "":
        return  # blank == root
    if not SUBDOMAIN_RE.match(s):
        raise CtlError(f"Invalid subdomain label: {s!r}")


def _parse_price_to_cents(price_str: str) -> int:
    """Parse a USD price string like '9.73' or '12' into integer cents."""
    if not isinstance(price_str, str):
        raise CtlError(f"Expected price as string, got {type(price_str).__name__}")
    s = price_str.strip().lstrip("$")
    if not re.match(r"^[0-9]+(\.[0-9]{1,2})?$", s):
        raise CtlError(f"Could not parse price string: {price_str!r}")
    if "." in s:
        whole, frac = s.split(".", 1)
        frac = (frac + "00")[:2]
    else:
        whole, frac = s, "00"
    return int(whole) * 100 + int(frac)


def _emit(obj: Any, json_mode: bool) -> None:
    if json_mode:
        print(json.dumps(obj, indent=2, default=str))
        return
    if isinstance(obj, list):
        if not obj:
            print("(empty)")
            return
        for x in obj:
            print(_format_summary(x))
    elif isinstance(obj, dict):
        print(json.dumps(obj, indent=2, default=str))
    else:
        print(obj)


def _format_summary(x: Any) -> str:
    if isinstance(x, dict):
        if "domain" in x and "status" in x:
            exp = x.get("expireDate") or x.get("expire_date") or "?"
            return f"{x.get('domain',''):<32}  status={x.get('status','?'):<10}  expires={exp}  autorenew={x.get('autoRenew', x.get('autorenew','?'))}"
        if "id" in x and "type" in x and "content" in x:
            name = x.get("name") or "(root)"
            return f"#{x['id']:<12} {name:<24} type={x.get('type','?'):<6} content={x.get('content','?')}  ttl={x.get('ttl','?')}  prio={x.get('prio','?')}"
        return json.dumps(x, default=str)
    return str(x)


def _load_body(args: argparse.Namespace) -> Any | None:
    if getattr(args, "data", None) and getattr(args, "body", None):
        raise CtlError("--data and --body are mutually exclusive.")
    if getattr(args, "data", None):
        try:
            return json.loads(args.data)
        except json.JSONDecodeError as e:
            raise CtlError(f"--data is not valid JSON: {e}") from None
    if getattr(args, "body", None):
        p = pathlib.Path(args.body).expanduser()
        if not p.is_file():
            raise CtlError(f"--body file not found: {p}")
        try:
            resolved = p.resolve()
            config_real = CONFIG_DIR.resolve()
            try:
                resolved.relative_to(config_real)
                raise CtlError(
                    f"Refusing --body inside {CONFIG_DIR} — that directory "
                    "holds API credentials and the SSL bundle store."
                )
            except ValueError:
                pass
        except OSError:
            pass
        try:
            return json.loads(p.read_text(encoding="utf-8"))
        except json.JSONDecodeError as e:
            raise CtlError(f"--body file {p} is not valid JSON: {e}") from None
    return None


def _parse_query(items: Iterable[str] | None) -> dict | None:
    if not items:
        return None
    out: dict = {}
    for item in items:
        if "=" not in item:
            raise CtlError(f"--query expects k=v pairs; got {item!r}")
        k, v = item.split("=", 1)
        out[k] = v
    return out


# ---------- Named commands -------------------------------------------------


def cmd_setup(args: argparse.Namespace) -> int:
    if not sys.stdin.isatty():
        raise CtlError(
            "setup must run in an interactive terminal (cannot read credentials from a non-TTY).\n"
            "If you're piping output or running under an AI agent, use `porkbun-api-skill gui-setup` "
            "instead (native OS dialog, AI cannot read the input)."
        )
    print(f"porkbun-api-skill {VERSION} setup — platform={_platform()}")
    print()

    existing = creds_get()
    if existing:
        try:
            who = _request(existing, "POST", "/ping", body={})
            ip = who.get("yourIp") or who.get("your_ip") or "(unknown ip)"
            valid = who.get("status") == "SUCCESS"
            label = f"valid={valid} ip={ip}"
        except CtlError:
            label = "(failed to authenticate — possibly revoked)"
        print(f"An existing credential pair is stored. /ping says: {label}")
        if not args.replace:
            ans = input("Replace it with a new credential pair? [y/N] ").strip().lower()
            if ans not in ("y", "yes"):
                print("Aborted; existing credentials left in place.")
                return 0

    print()
    print("Generate (or copy) a credential pair from:")
    print("  https://porkbun.com/account/api")
    print("API key starts with `pk1_`. Secret API key starts with `sk1_`.")
    print()
    apikey = getpass.getpass("Paste API key (input hidden): ").strip()
    if not apikey:
        raise CtlError("Empty API key; aborting.")
    if any(c.isspace() for c in apikey) or len(apikey) < 20:
        raise CtlError("API key looks malformed (too short or contains whitespace).")
    secretapikey = getpass.getpass("Paste SECRET API key (input hidden): ").strip()
    if not secretapikey:
        raise CtlError("Empty secret API key; aborting.")
    if any(c.isspace() for c in secretapikey) or len(secretapikey) < 20:
        raise CtlError("Secret API key looks malformed (too short or contains whitespace).")

    print("Verifying with /ping ...")
    resp = _request((apikey, secretapikey), "POST", "/ping", body={})
    if resp.get("status") != "SUCCESS":
        raise CtlError(f"Porkbun rejected the credentials: {resp.get('message') or resp}")
    ip = resp.get("yourIp") or "(unknown)"
    where = creds_set(apikey, secretapikey, prefer=("file" if args.file else None))
    print(f"Credentials stored in: {where}")
    print(f"Authenticated caller IP: {ip}")
    if existing:
        print("Old credentials replaced. If the old keys are still valid on Porkbun's side, "
              "revoke them at https://porkbun.com/account/api.")
    return 0


def cmd_gui_setup(args: argparse.Namespace) -> int:
    print(f"porkbun-api-skill {VERSION} gui-setup — platform={_platform()}")
    print("Native password dialog(s) will appear on your desktop. The AI cannot read what you type.")
    print("If you don't see the dialog, look on another desktop or behind other windows.")
    print()

    existing = creds_get()
    label = "(no existing credentials)"
    if existing:
        try:
            who = _request(existing, "POST", "/ping", body={})
            valid = who.get("status") == "SUCCESS"
            ip = who.get("yourIp") or "(unknown)"
            label = f"valid={valid} ip={ip}"
        except CtlError:
            label = "(failed to authenticate — possibly revoked)"
        print(f"An existing credential pair is stored: {label}")
        if not args.replace:
            ok = _confirm_gui(f"Replace the existing Porkbun credentials?\nCurrent: {label}")
            if not ok:
                print("Aborted; existing credentials left in place.")
                return 0

    print("Waiting for credential entry in the desktop dialog(s)...")
    apikey, secretapikey = _prompt_creds_gui()
    if not apikey or not secretapikey:
        raise CtlError("Empty credential value; aborting.")
    if any(c.isspace() for c in apikey) or any(c.isspace() for c in secretapikey):
        raise CtlError("Credentials contain whitespace; aborting. Re-run gui-setup and paste cleanly.")
    if len(apikey) < 20 or len(secretapikey) < 20:
        raise CtlError("Credentials look too short; aborting. Re-run gui-setup.")

    print("Verifying with /ping ...")
    resp = _request((apikey, secretapikey), "POST", "/ping", body={})
    if resp.get("status") != "SUCCESS":
        raise CtlError(f"Porkbun rejected the credentials: {resp.get('message') or resp}")
    ip = resp.get("yourIp") or "(unknown)"
    where = creds_set(apikey, secretapikey, prefer=("file" if args.file else None))
    print(f"Credentials stored in: {where}")
    print(f"Authenticated caller IP: {ip}")
    if existing:
        print("Old credentials replaced. Revoke the old keys at https://porkbun.com/account/api "
              "if they are still active.")
    return 0


def cmd_uninstall_credentials(args: argparse.Namespace) -> int:
    if not args.yes:
        raise CtlError("Refusing to delete stored credentials without --yes.")
    removed = creds_delete()
    if not removed:
        print("No stored credentials to remove.")
    else:
        for r in removed:
            print(f"Removed credentials from: {r}")
    return 0


def cmd_whoami(args: argparse.Namespace) -> int:
    creds = _load_creds()
    resp = _request(creds, "POST", "/ping", body={})
    safe = {
        "credentialsValid": resp.get("status") == "SUCCESS",
        "yourIp": resp.get("yourIp"),
        "status": resp.get("status"),
        "message": resp.get("message"),
    }
    _emit(safe, args.json)
    return 0


def cmd_balance(args: argparse.Namespace) -> int:
    creds = _load_creds()
    resp = _request(creds, "GET", "/account/balance")
    _emit(resp, args.json)
    return 0


def cmd_domains(args: argparse.Namespace) -> int:
    creds = _load_creds()
    extra: dict[str, Any] = {}
    if args.expiring_within_days is not None:
        extra["expiringWithinDays"] = args.expiring_within_days
    if args.name_contains:
        extra["nameContains"] = args.name_contains
    if args.tlds:
        extra["tlds"] = args.tlds
    domains = _paginate_listall(creds, extra_body=extra or None)
    _emit(domains, args.json)
    return 0


def cmd_domain(args: argparse.Namespace) -> int:
    creds = _load_creds()
    _validate_domain(args.domain)
    resp = _request(creds, "GET", f"/domain/get/{args.domain}")
    _emit(resp, args.json)
    return 0


def cmd_price(args: argparse.Namespace) -> int:
    creds = _load_creds()
    _validate_domain(args.domain)
    resp = _request(creds, "POST", f"/domain/checkDomain/{args.domain}", body={})
    if not args.json:
        r = resp.get("response", {})
        avail = r.get("avail", "?")
        price = r.get("price", "?")
        promo = r.get("firstYearPromo", "?")
        reg = r.get("regularPrice", "?")
        premium = r.get("premium", "?")
        renewal = ((r.get("additional") or {}).get("renewal") or {}).get("price", "?")
        transfer = ((r.get("additional") or {}).get("transfer") or {}).get("price", "?")
        print(f"{args.domain}: available={avail}  premium={premium}")
        print(f"  registration:  ${price}  (regular ${reg}, firstYearPromo={promo})")
        print(f"  renewal:       ${renewal}")
        print(f"  transfer-in:   ${transfer}")
        try:
            print(f"  cost-cents:    --cost-cents {_parse_price_to_cents(price)} "
                  f"(for `porkbun-api-skill register`)")
        except CtlError:
            pass
    else:
        _emit(resp, True)
    return 0


def _verify_price(creds: tuple[str, str], domain: str, kind: str, cost_cents: int) -> None:
    """Re-fetch /domain/checkDomain and refuse if quoted price != cost_cents.

    kind is one of: 'registration' / 'renewal' / 'transfer'.
    """
    resp = _request(creds, "POST", f"/domain/checkDomain/{domain}", body={})
    r = resp.get("response") or {}
    if kind == "registration":
        quoted = r.get("price")
    elif kind == "renewal":
        quoted = ((r.get("additional") or {}).get("renewal") or {}).get("price")
    elif kind == "transfer":
        quoted = ((r.get("additional") or {}).get("transfer") or {}).get("price")
    else:
        raise CtlError(f"_verify_price: unknown kind {kind!r}")
    if quoted is None:
        raise CtlError(f"Porkbun did not return a {kind} price for {domain}. Aborting.")
    quoted_cents = _parse_price_to_cents(quoted)
    if quoted_cents != cost_cents:
        raise CtlError(
            f"Price mismatch for {domain} ({kind}): you confirmed {cost_cents} cents "
            f"(${cost_cents/100:.2f}), but Porkbun's current quote is {quoted_cents} cents "
            f"(${quoted_cents/100:.2f}). Re-run `porkbun-api-skill price {domain}` and confirm the new amount."
        )


def _check_billing_flags(args: argparse.Namespace) -> None:
    if not args.yes:
        raise CtlError("Refusing billable op without --yes.")
    if not args.i_understand_billing:
        raise CtlError(
            "Refusing billable op without --i-understand-billing. "
            "This call CHARGES YOUR PORKBUN ACCOUNT CREDIT. "
            "Re-quote with `porkbun-api-skill price <domain>` and re-confirm $X.YZ before proceeding."
        )
    if args.cost_cents is None:
        raise CtlError(
            "Refusing billable op without --cost-cents <N>. "
            "Run `porkbun-api-skill price <domain>` first; pass the quoted cents."
        )


def cmd_register(args: argparse.Namespace) -> int:
    _validate_domain(args.domain)
    _check_billing_flags(args)
    creds = _load_creds()
    _verify_price(creds, args.domain, "registration", args.cost_cents)
    body: dict[str, Any] = {"cost": args.cost_cents, "agreeToTerms": "yes"}
    if args.dry_run:
        _emit({"would_post": f"/domain/create/{args.domain}", "body": body}, args.json)
        return 0
    idem_key = args.idempotency_key or uuid.uuid4().hex
    _audit("register", args.domain,
           {"cost_cents": args.cost_cents, "idempotency_key": idem_key, "classification": "billable"})
    resp = _request(creds, "POST", f"/domain/create/{args.domain}",
                    body=body, idempotency_key=idem_key)
    print(f"Register requested: {args.domain} for {args.cost_cents} cents (${args.cost_cents/100:.2f}).")
    print(f"Idempotency key: {idem_key}")
    _emit(resp, args.json)
    return 0


def cmd_renew(args: argparse.Namespace) -> int:
    _validate_domain(args.domain)
    _check_billing_flags(args)
    creds = _load_creds()
    _verify_price(creds, args.domain, "renewal", args.cost_cents)
    body: dict[str, Any] = {"cost": args.cost_cents}
    if args.years:
        body["years"] = args.years
    if args.dry_run:
        _emit({"would_post": f"/domain/renew/{args.domain}", "body": body}, args.json)
        return 0
    idem_key = args.idempotency_key or uuid.uuid4().hex
    _audit("renew", args.domain,
           {"cost_cents": args.cost_cents, "years": args.years,
            "idempotency_key": idem_key, "classification": "billable"})
    resp = _request(creds, "POST", f"/domain/renew/{args.domain}",
                    body=body, idempotency_key=idem_key)
    print(f"Renew requested: {args.domain} for {args.cost_cents} cents (${args.cost_cents/100:.2f}).")
    print(f"Idempotency key: {idem_key}")
    _emit(resp, args.json)
    return 0


def cmd_transfer(args: argparse.Namespace) -> int:
    _validate_domain(args.domain)
    _check_billing_flags(args)
    if not args.auth_code:
        raise CtlError("Refusing transfer without --auth-code <EPP code from losing registrar>.")
    creds = _load_creds()
    _verify_price(creds, args.domain, "transfer", args.cost_cents)
    body: dict[str, Any] = {"authCode": args.auth_code, "cost": args.cost_cents}
    if args.dry_run:
        redacted = {**body, "authCode": "<redacted>"}
        _emit({"would_post": f"/domain/transfer/{args.domain}", "body": redacted}, args.json)
        return 0
    idem_key = args.idempotency_key or uuid.uuid4().hex
    _audit("transfer", args.domain,
           {"cost_cents": args.cost_cents, "idempotency_key": idem_key, "classification": "billable"})
    resp = _request(creds, "POST", f"/domain/transfer/{args.domain}",
                    body=body, idempotency_key=idem_key)
    print(f"Transfer requested: {args.domain} for {args.cost_cents} cents (${args.cost_cents/100:.2f}).")
    print(f"Idempotency key: {idem_key}")
    _emit(resp, args.json)
    return 0


def cmd_auto_renew(args: argparse.Namespace) -> int:
    _validate_domain(args.domain)
    if not args.yes:
        raise CtlError("Refusing to toggle auto-renew without --yes.")
    if not (args.on or args.off):
        raise CtlError("Pass --on or --off.")
    if args.on and args.off:
        raise CtlError("--on and --off are mutually exclusive.")
    status = "on" if args.on else "off"
    creds = _load_creds()
    body = {"status": status}
    if args.dry_run:
        _emit({"would_post": f"/domain/updateAutoRenew/{args.domain}", "body": body}, args.json)
        return 0
    idem_key = uuid.uuid4().hex
    _audit("auto-renew", args.domain,
           {"status": status, "idempotency_key": idem_key, "classification": "mutating"})
    resp = _request(creds, "POST", f"/domain/updateAutoRenew/{args.domain}",
                    body=body, idempotency_key=idem_key)
    print(f"Auto-renew for {args.domain}: set to {status}.")
    _emit(resp, args.json)
    return 0


def cmd_nameservers(args: argparse.Namespace) -> int:
    _validate_domain(args.domain)
    creds = _load_creds()
    if args.get:
        resp = _request(creds, "GET", f"/domain/getNs/{args.domain}")
        if not args.json:
            ns = resp.get("ns") or resp.get("nameservers") or []
            print(f"{args.domain} nameservers:")
            for n in ns:
                print(f"  {n}")
        else:
            _emit(resp, True)
        return 0
    if not args.set:
        raise CtlError("Pass --get or --set ns1,ns2,...")
    if not args.yes:
        raise CtlError("Refusing to update nameservers without --yes.")
    ns_list = [n.strip() for n in args.set.split(",") if n.strip()]
    if len(ns_list) < 2:
        raise CtlError("Refusing to set fewer than 2 nameservers (registries require at least 2).")
    for n in ns_list:
        if not DOMAIN_RE.match(n):
            raise CtlError(f"Invalid nameserver hostname: {n!r}")
    body = {"ns": ns_list}
    if args.dry_run:
        _emit({"would_post": f"/domain/updateNs/{args.domain}", "body": body}, args.json)
        return 0
    idem_key = uuid.uuid4().hex
    _audit("nameservers", args.domain,
           {"ns": ns_list, "idempotency_key": idem_key, "classification": "mutating"})
    resp = _request(creds, "POST", f"/domain/updateNs/{args.domain}",
                    body=body, idempotency_key=idem_key)
    print(f"Nameservers for {args.domain} updated: {ns_list}")
    _emit(resp, args.json)
    return 0


def cmd_dns_list(args: argparse.Namespace) -> int:
    _validate_domain(args.domain)
    creds = _load_creds()
    resp = _request(creds, "GET", f"/dns/retrieve/{args.domain}")
    records = resp.get("records") or []
    _emit(records, args.json)
    return 0


def cmd_dns_add(args: argparse.Namespace) -> int:
    _validate_domain(args.domain)
    if not DNS_TYPE_RE.match(args.type):
        raise CtlError(f"Invalid DNS record type: {args.type!r}")
    if not args.yes:
        raise CtlError("Refusing to add DNS record without --yes.")
    sub = args.subdomain or ""
    _validate_subdomain_label(sub)
    body: dict[str, Any] = {
        "type": args.type,
        "content": args.content,
    }
    if sub:
        body["name"] = sub
    if args.ttl is not None:
        body["ttl"] = str(args.ttl)
    if args.prio is not None:
        body["prio"] = str(args.prio)
    if args.notes:
        body["notes"] = args.notes
    if args.dry_run:
        _emit({"would_post": f"/dns/create/{args.domain}", "body": body}, args.json)
        return 0
    idem_key = uuid.uuid4().hex
    _audit("dns-add", args.domain,
           {"type": args.type, "subdomain": sub, "ttl": args.ttl,
            "idempotency_key": idem_key, "classification": "mutating",
            "body_keys": sorted(body.keys())})
    resp = _request(creds := _load_creds(), "POST", f"/dns/create/{args.domain}",
                    body=body, idempotency_key=idem_key)
    print(f"DNS record added to {args.domain}: type={args.type} sub={sub or '(root)'} content={args.content}")
    _emit(resp, args.json)
    return 0


def cmd_dns_edit(args: argparse.Namespace) -> int:
    _validate_domain(args.domain)
    if not RECORD_ID_RE.match(args.id):
        raise CtlError(f"Invalid record id (must be numeric): {args.id!r}")
    if not args.yes:
        raise CtlError("Refusing to edit DNS record without --yes.")
    if not args.confirm_id:
        raise CtlError("Refusing to edit DNS record without --confirm-id <id>.")
    if args.confirm_id != args.id:
        raise CtlError(
            f"--confirm-id mismatch: --id was {args.id!r}, --confirm-id was {args.confirm_id!r}."
        )
    if not DNS_TYPE_RE.match(args.type):
        raise CtlError(f"Invalid DNS record type: {args.type!r}")
    sub = args.subdomain or ""
    _validate_subdomain_label(sub)
    body: dict[str, Any] = {
        "type": args.type,
        "content": args.content,
    }
    if sub:
        body["name"] = sub
    if args.ttl is not None:
        body["ttl"] = str(args.ttl)
    if args.prio is not None:
        body["prio"] = str(args.prio)
    if args.notes is not None:
        body["notes"] = args.notes
    if args.dry_run:
        _emit({"would_post": f"/dns/edit/{args.domain}/{args.id}", "body": body}, args.json)
        return 0
    idem_key = uuid.uuid4().hex
    _audit("dns-edit", f"{args.domain}/{args.id}",
           {"type": args.type, "subdomain": sub, "idempotency_key": idem_key,
            "classification": "mutating", "body_keys": sorted(body.keys())})
    resp = _request(_load_creds(), "POST", f"/dns/edit/{args.domain}/{args.id}",
                    body=body, idempotency_key=idem_key)
    print(f"DNS record {args.id} on {args.domain} edited: type={args.type} content={args.content}")
    _emit(resp, args.json)
    return 0


def cmd_dns_delete(args: argparse.Namespace) -> int:
    _validate_domain(args.domain)
    if not RECORD_ID_RE.match(args.id):
        raise CtlError(f"Invalid record id (must be numeric): {args.id!r}")
    if not args.yes:
        raise CtlError("Refusing to delete DNS record without --yes.")
    if not args.confirm_id:
        raise CtlError("Refusing to delete DNS record without --confirm-id <id>.")
    if args.confirm_id != args.id:
        raise CtlError(
            f"--confirm-id mismatch: --id was {args.id!r}, --confirm-id was {args.confirm_id!r}."
        )
    if args.dry_run:
        _emit({"would_post": f"/dns/delete/{args.domain}/{args.id}"}, args.json)
        return 0
    idem_key = uuid.uuid4().hex
    _audit("dns-delete", f"{args.domain}/{args.id}",
           {"idempotency_key": idem_key, "classification": "destructive"})
    resp = _request(_load_creds(), "POST", f"/dns/delete/{args.domain}/{args.id}",
                    body={}, idempotency_key=idem_key)
    print(f"DNS record {args.id} on {args.domain} deleted.")
    _emit(resp, args.json)
    return 0


def cmd_ssl(args: argparse.Namespace) -> int:
    _validate_domain(args.domain)
    if not args.yes:
        raise CtlError("Refusing SSL retrieve without --yes.")
    if not args.allow_privilege:
        raise CtlError(
            "Refusing SSL retrieve without --allow-privilege. "
            "The response contains private key material — treat like a credential."
        )
    creds = _load_creds()
    resp = _request(creds, "POST", f"/ssl/retrieve/{args.domain}", body={})
    if resp.get("status") != "SUCCESS":
        raise CtlError(f"Porkbun returned: {resp.get('message') or resp}")
    SSL_DIR.mkdir(parents=True, exist_ok=True)
    if os.name == "posix":
        try:
            os.chmod(SSL_DIR, 0o700)
        except OSError:
            pass
    ts = dt.datetime.now(dt.timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    written: list[str] = []
    for key in ("certificatechain", "privatekey", "publickey"):
        if key not in resp:
            continue
        path = SSL_DIR / f"{args.domain}.{ts}.{key}.pem"
        fd = os.open(str(path), os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
        try:
            os.write(fd, resp[key].encode("utf-8"))
        finally:
            os.close(fd)
        if os.name == "posix":
            os.chmod(path, 0o600)
        written.append(str(path))
    _audit("ssl-retrieve", args.domain,
           {"files": written, "classification": "privilege"})
    print(f"SSL bundle for {args.domain} written to (mode 0600):")
    for w in written:
        print(f"  {w}")
    print("WARNING: privatekey.pem contains your domain's private key. Treat it as a secret.")
    return 0


def cmd_audit_log(args: argparse.Namespace) -> int:
    if not AUDIT_LOG.exists():
        print("(audit log empty)")
        return 0
    with AUDIT_LOG.open("r", encoding="utf-8") as f:
        lines = f.readlines()
    if args.last:
        lines = lines[-args.last :]
    for line in lines:
        print(line.rstrip())
    return 0


def cmd_classify(args: argparse.Namespace) -> int:
    cls, flags, why = classify(args.method, args.path)
    out = {
        "method": args.method.upper(),
        "path": args.path,
        "normalized": _normalize_path(args.path),
        "classification": cls,
        "required_flags": flags,
        "explanation": why,
    }
    _emit(out, args.json)
    return 0


# ---------- Generic API command --------------------------------------------


def cmd_api(args: argparse.Namespace) -> int:
    method = args.method.upper()
    if method not in {"GET", "POST"}:
        raise CtlError(f"Porkbun API only uses GET and POST; got {method!r}.")
    _validate_path(args.path)
    api_path = _strip_v3(args.path)

    cls, required, why = classify(method, args.path)
    missing: list[str] = []
    if "--yes" in required and not args.yes:
        missing.append("--yes")
    if "--confirm-id" in required:
        if not args.confirm_id:
            missing.append("--confirm-id")
        else:
            last = args.path.rstrip("/").split("/")[-1]
            if args.confirm_id != last:
                raise CtlError(
                    f"--confirm-id mismatch: path ends with {last!r} but --confirm-id was {args.confirm_id!r}."
                )
    if "--confirm-name" in required:
        if not args.confirm_name:
            missing.append("--confirm-name")
        else:
            last = args.path.rstrip("/").split("/")[-1]
            if args.confirm_name != last:
                raise CtlError(
                    f"--confirm-name mismatch: path ends with {last!r} but --confirm-name was {args.confirm_name!r}."
                )
    if "--i-understand-billing" in required and not args.i_understand_billing:
        missing.append("--i-understand-billing")
    if "--i-understand-billing" in required and args.cost_cents is None:
        missing.append("--cost-cents")
    if "--allow-privilege" in required and not args.allow_privilege:
        missing.append("--allow-privilege")
    if missing:
        raise CtlError(
            f"Refusing {method} {args.path}: classification={cls}; missing flags: {' '.join(missing)}.\n"
            f"  reason: {why}\n"
            f"  required: {' '.join(required)}\n"
            f"  see `porkbun-api-skill classify {method} '{args.path}'` for details."
        )

    body = _load_body(args)
    query = _parse_query(args.query)

    # For billable ops via raw `api`, re-verify the price as a safety belt.
    if cls == "billable":
        norm = _normalize_path(args.path)
        # Pull the {domain} segment from the path.
        tparts = norm.strip("/").split("/")
        pparts = api_path.strip("/").split("/")
        domain = None
        for t, p in zip(tparts, pparts):
            if t == "{domain}":
                domain = p
                break
        kind_map = {
            "/domain/create/{domain}": "registration",
            "/domain/renew/{domain}": "renewal",
            "/domain/transfer/{domain}": "transfer",
        }
        kind = kind_map.get(norm)
        if domain and kind and args.cost_cents is not None:
            _verify_price(_load_creds(), domain, kind, args.cost_cents)
            if isinstance(body, dict):
                body.setdefault("cost", args.cost_cents)
                if kind == "registration":
                    body.setdefault("agreeToTerms", "yes")

    if args.dry_run:
        _emit({
            "method": method,
            "path": args.path,
            "classification": cls,
            "would_send_body": body,
            "query": query,
            "idempotency_key": args.idempotency_key or ("<auto-uuid4>" if method == "POST" and not args.no_idempotency_key else None),
        }, args.json)
        return 0

    creds = _load_creds()
    idem_key = args.idempotency_key
    attach = not args.no_idempotency_key

    result = _request(
        creds, method, api_path,
        body=body, query=query,
        idempotency_key=idem_key, attach_idempotency=attach,
    )

    if cls != "read":
        _audit(
            f"api:{method.lower()}",
            args.path,
            {
                "classification": cls,
                "idempotency_key": idem_key or ("auto" if attach and method == "POST" else None),
                "body_keys": sorted(body.keys()) if isinstance(body, dict) else None,
            },
        )

    print(json.dumps(result, indent=2, default=str))
    return 0


# ---------- Argparse -------------------------------------------------------


def _add_mut(p: argparse.ArgumentParser) -> None:
    p.add_argument("--yes", action="store_true", help="Confirm intent (required for mutations).")
    p.add_argument("--dry-run", action="store_true", help="Print what would be sent; do not call API.")


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="porkbun-api-skill",
        description=f"porkbun-api-skill {VERSION} — safe CLI for the Porkbun v3 API.",
        epilog="Run `porkbun-api-skill <subcmd> --help` for per-command flags.",
    )
    p.add_argument("--json", action="store_true", help="Emit JSON output where applicable.")
    p.add_argument("--version", action="version",
                   version=f"porkbun-api-skill {VERSION} (AI-authored by Claude — see AUTHORS.md)")
    sub = p.add_subparsers(dest="cmd", required=True)

    # ---- meta
    p_setup = sub.add_parser(
        "setup",
        help="Add or replace the credential pair (terminal, interactive). Requires a TTY — AI agents cannot run this.",
    )
    p_setup.add_argument("--file", action="store_true",
                         help="Force file storage even if a system keystore is available.")
    p_setup.add_argument("--replace", action="store_true",
                         help="Skip the 'replace existing credentials?' prompt.")
    p_setup.set_defaults(func=cmd_setup)

    p_gui = sub.add_parser(
        "gui-setup",
        help="Add or replace credentials via a native desktop dialog. AI-runnable: AI never sees the keys.",
    )
    p_gui.add_argument("--file", action="store_true")
    p_gui.add_argument("--replace", action="store_true")
    p_gui.set_defaults(func=cmd_gui_setup)

    p_un = sub.add_parser("uninstall-credentials", help="Remove the stored credential pair.")
    p_un.add_argument("--yes", action="store_true")
    p_un.set_defaults(func=cmd_uninstall_credentials)

    sub.add_parser("whoami", help="Verify auth via /ping; print credentialsValid + caller IP.").set_defaults(func=cmd_whoami)

    sub.add_parser("balance", help="Show account credit (/account/balance).").set_defaults(func=cmd_balance)

    p_cls = sub.add_parser("classify", help="Show how a method+path would be classified.")
    p_cls.add_argument("method")
    p_cls.add_argument("path")
    p_cls.set_defaults(func=cmd_classify)

    # ---- domains
    p_doms = sub.add_parser("domains", help="List all domains (paginated).")
    p_doms.add_argument("--expiring-within-days", type=int)
    p_doms.add_argument("--name-contains")
    p_doms.add_argument("--tlds", action="append", help="Limit to these TLDs (repeatable). e.g. --tlds com --tlds io")
    p_doms.set_defaults(func=cmd_domains)

    p_dom = sub.add_parser("domain", help="Show one domain (/domain/get/{domain}).")
    p_dom.add_argument("domain")
    p_dom.set_defaults(func=cmd_domain)

    p_price = sub.add_parser("price", help="Check availability + price (/domain/checkDomain/{domain}).")
    p_price.add_argument("domain")
    p_price.set_defaults(func=cmd_price)

    p_reg = sub.add_parser("register", help="Register a new domain. BILLABLE — charges account credit.")
    p_reg.add_argument("domain")
    p_reg.add_argument("--cost-cents", type=int, required=False,
                       help="Cost in pennies; must match Porkbun's current /domain/checkDomain quote.")
    p_reg.add_argument("--i-understand-billing", action="store_true")
    p_reg.add_argument("--idempotency-key", help="Operator-supplied idempotency key. If omitted, the CLI generates a UUIDv4.")
    _add_mut(p_reg)
    p_reg.set_defaults(func=cmd_register)

    p_ren = sub.add_parser("renew", help="Renew a domain. BILLABLE.")
    p_ren.add_argument("domain")
    p_ren.add_argument("--cost-cents", type=int, required=False)
    p_ren.add_argument("--years", type=int)
    p_ren.add_argument("--i-understand-billing", action="store_true")
    p_ren.add_argument("--idempotency-key")
    _add_mut(p_ren)
    p_ren.set_defaults(func=cmd_renew)

    p_tr = sub.add_parser("transfer", help="Inbound transfer of a domain. BILLABLE.")
    p_tr.add_argument("domain")
    p_tr.add_argument("--cost-cents", type=int, required=False)
    p_tr.add_argument("--auth-code", help="EPP auth code from the losing registrar.")
    p_tr.add_argument("--i-understand-billing", action="store_true")
    p_tr.add_argument("--idempotency-key")
    _add_mut(p_tr)
    p_tr.set_defaults(func=cmd_transfer)

    p_ar = sub.add_parser("auto-renew", help="Toggle auto-renew on/off.")
    p_ar.add_argument("domain")
    p_ar.add_argument("--on", action="store_true")
    p_ar.add_argument("--off", action="store_true")
    _add_mut(p_ar)
    p_ar.set_defaults(func=cmd_auto_renew)

    p_ns = sub.add_parser("nameservers", help="Get or set nameservers.")
    p_ns.add_argument("domain")
    p_ns.add_argument("--get", action="store_true")
    p_ns.add_argument("--set", help="Comma-separated NS list, e.g. ns1.example.com,ns2.example.com")
    _add_mut(p_ns)
    p_ns.set_defaults(func=cmd_nameservers)

    # ---- DNS
    p_dns = sub.add_parser("dns", help="DNS record operations.")
    p_dns_sub = p_dns.add_subparsers(dest="dns_cmd", required=True)

    p_dl = p_dns_sub.add_parser("list", help="List DNS records.")
    p_dl.add_argument("domain")
    p_dl.set_defaults(func=cmd_dns_list)

    p_da = p_dns_sub.add_parser("add", help="Create a DNS record.")
    p_da.add_argument("domain")
    p_da.add_argument("--type", required=True)
    p_da.add_argument("--content", required=True)
    p_da.add_argument("--subdomain", default="", help="Subdomain part only (no domain). Blank = root.")
    p_da.add_argument("--ttl", type=int)
    p_da.add_argument("--prio", type=int)
    p_da.add_argument("--notes")
    _add_mut(p_da)
    p_da.set_defaults(func=cmd_dns_add)

    p_de = p_dns_sub.add_parser("edit", help="Edit a DNS record by id.")
    p_de.add_argument("domain")
    p_de.add_argument("--id", required=True)
    p_de.add_argument("--confirm-id", required=False,
                      help="Must equal --id. Required because edits to A/AAAA/MX/NS can take down production.")
    p_de.add_argument("--type", required=True)
    p_de.add_argument("--content", required=True)
    p_de.add_argument("--subdomain", default="")
    p_de.add_argument("--ttl", type=int)
    p_de.add_argument("--prio", type=int)
    p_de.add_argument("--notes")
    _add_mut(p_de)
    p_de.set_defaults(func=cmd_dns_edit)

    p_dd = p_dns_sub.add_parser("delete", help="Delete a DNS record by id.")
    p_dd.add_argument("domain")
    p_dd.add_argument("--id", required=True)
    p_dd.add_argument("--confirm-id", required=False, help="Must equal --id.")
    _add_mut(p_dd)
    p_dd.set_defaults(func=cmd_dns_delete)

    # ---- SSL
    p_ssl = sub.add_parser("ssl", help="Retrieve SSL bundle. PRIVILEGE — response contains private key.")
    p_ssl.add_argument("domain")
    p_ssl.add_argument("--allow-privilege", action="store_true")
    _add_mut(p_ssl)
    p_ssl.set_defaults(func=cmd_ssl)

    # ---- audit
    p_aud = sub.add_parser("audit-log", help="Print local audit log of mutations.")
    p_aud.add_argument("--last", type=int)
    p_aud.set_defaults(func=cmd_audit_log)

    # ---- generic api
    p_api = sub.add_parser(
        "api",
        help="Generic API call: porkbun-api-skill api <METHOD> <path> [flags]. "
             "Safety classifier enforces required flags.",
    )
    p_api.add_argument("method", help="GET or POST")
    p_api.add_argument("path", help="Path under /v3, e.g. /domain/listAll")
    p_api.add_argument("--query", action="append", help="k=v query string param. Repeatable.")
    grp = p_api.add_mutually_exclusive_group()
    grp.add_argument("--data", help="Inline JSON body string.")
    grp.add_argument("--body", help="Path to a JSON file to send as body.")
    p_api.add_argument("--paginate", action="store_true",
                       help="(Reserved; pagination is handled by the named `domains` command.)")
    p_api.add_argument("--yes", action="store_true")
    p_api.add_argument("--confirm-id")
    p_api.add_argument("--confirm-name")
    p_api.add_argument("--i-understand-billing", action="store_true")
    p_api.add_argument("--cost-cents", type=int)
    p_api.add_argument("--allow-privilege", action="store_true")
    p_api.add_argument("--idempotency-key",
                       help="Operator-supplied idempotency key. If omitted on a POST, the CLI generates a UUIDv4.")
    p_api.add_argument("--no-idempotency-key", action="store_true",
                       help="DEBUG ONLY: do not attach an Idempotency-Key header. Unsafe for production scripts.")
    p_api.add_argument("--dry-run", action="store_true")
    p_api.set_defaults(func=cmd_api)

    return p


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        return args.func(args)
    except CtlError as e:
        print(f"error: {e}", file=sys.stderr)
        return 2
    except KeyboardInterrupt:
        print("interrupted", file=sys.stderr)
        return 130


if __name__ == "__main__":
    sys.exit(main())
